{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/librarian-read.sh\"",
            "timeout": 5,
            "statusMessage": "Loading library context..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/librarian-write.sh\"",
            "timeout": 10,
            "statusMessage": "Syncing learnings to library..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/librarian-read.sh\"",
            "timeout": 5,
            "statusMessage": "Loading library context..."
          }
        ]
      }
    ]
  }
}
